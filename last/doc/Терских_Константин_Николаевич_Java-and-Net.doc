}\cell\pard\intbl\itap1{\fs50\b \uc0\u1058 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1085  \uc0\u1053 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 , 51\uc0\u160 \uc0\u1075 \uc0\u1086 \uc0\u1076 , \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083 \uc0\u1089 \uc0\u1103  16 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1103  1974}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (911)\uc0\u160 7854106 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 } {\cf1  \uc0\u8226  } {\cf1@kostus_online}\par {{\field{\*\fldinst HYPERLINK "mailto:kostus.online@gmail.com"}{\fldrslt\ul kostus.online@gmail.com}}}\par telegram: @kostus_online\par Telegram: https://t.me/kostus_online}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1057 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1090 -\uc0\u1055 \uc0\u1077 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 , \uc0\u1084 . \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 , \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1043 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1077 \uc0\u1079 \uc0\u1076 \uc0\u1091 : \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , \uc0\u1085 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx6861\clvertalt\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082  Java, .Net}\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 :  }\par\li300{\uc0\u8212   \uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \par\uc0\u8212   \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1089 \uc0\u1090 , \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 \par\uc0\u8212   \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \par\uc0\u8212   \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1087 \uc0\u1099  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080 \par\uc0\u8212   \uc0\u1057 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1058 \uc0\u1080 \uc0\u1087  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 /\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \par \uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1073 \uc0\u1086 \uc0\u1083 \uc0\u1077 \uc0\u1077  \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1072 }}\cell \pard\intbl\itap1\qr{\fs32\qc\b 180\uc0\u160 000\fs18\sl260  \uc0\u8381  \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1080 }\par\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 25 \uc0\u1083 \uc0\u1077 \uc0\u1090 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1057 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2024 \emdash  \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103 \line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b Skyeng/Skypro}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , sky.pro/}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 Java-\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 \par}\pard\intbl\itap1\sl260\sa60{\fs18 - Java Core, StreamAPI; \uc0\u1054 \uc0\u1054 \uc0\u1055 ; SOLID / KISS / DRY / YAGNI etc.;{\line}- JUnit, Mockito, Postman, Swagger UI;{\line}- Spring Boot 3.4.*; StreamAPI;{\line}- SQL: JPA/Hibernate; JdbcTemplate; PostgreSQL, MS SQL Server, MySQL;{\line}- NoSQL: Redis, MongoDB; Liquibase;{\line}- RESTful API; OpenAPI/Swagger, JavaDoc;{\line}- Linux, maven, VS Code; git, GitHub, GitHub Actions;{\line}- Docker, Kubernates;{\line}{\line}https://github.com/taker1974}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2020 \emdash  \uc0\u1057 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u110