7 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1040 \uc0\u1057 \uc0\u1059  \uc0\u1058 \uc0\u1055 :{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 -\uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1105 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1099  \uc0\u1080  \uc0\u1090 .\uc0\u1087 . {\line}- \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1058 \uc0\u1050 \uc0\u1055 , \uc0\u1058 \uc0\u1047 , \uc0\u1055 \uc0\u1047 ;{\line}- \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1094 \uc0\u1077 \uc0\u1087 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1040 \uc0\u1057 \uc0\u1059 , \uc0\u1074 \uc0\u1099 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1086 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1089 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 .{\line}- \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1082 \uc0\u1072 , \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2008 \emdash  \uc0\u1054 \uc0\u1082 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2008\line 10 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1057 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1092 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1050 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1103 \uc0\u1088 \uc0\u1089 \uc0\u1082 }\par{\fs18 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1091 \uc0\u1095 \uc0\u1088 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1042 \uc0\u1091 \uc0\u1079 , \uc0\u1089 \uc0\u1089 \uc0\u1091 \uc0\u1079  \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1083 \uc0\u1077 \uc0\u1076 \uc0\u1078 , \uc0\u1055 \uc0\u1058 \uc0\u1059 }}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1087 \uc0\u1099  \uc0\u1089 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1042 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1083  \uc0\u1089 \uc0\u1083 \uc0\u1080 \uc0\u1103 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1092 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  4-\uc0\u1093  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1042 \uc0\u1059 \uc0\u1047 \uc0\u1086 \uc0\u1074  \uc0\u1074  \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1091  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1057 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1060 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1059 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 \uc0\u1072 :{\line}- \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1083 \uc0\u1086 \uc0\u1097 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 , \uc0\u1074 \uc0\u1099 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1103 \uc0\u1097 \uc0\u1080 \uc0\u1093  \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 ;{\line}- \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1055 \uc0\u1054  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1088  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1072  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 ;{\line}- 1\uc0\u1057 :\uc0\u1055 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1077 , \uc0\u1050 \uc0\u1048 \uc0\u1057  "\uc0\u1060 \uc0\u1083 \uc0\u1072 \uc0\u1075 \uc0\u1084 \uc0\u1072 \uc0\u1085 ".}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1082 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2004 \emdash  \uc0\u1044 \uc0\u1077 \uc0\u1082 \uc0\u1072 \uc0\u1073 \uc0\u1088 \uc0\u1100  2007\line 3 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072  3 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1058 \uc0\u1086 \uc0\u1082 \uc0\u1089 \uc0\u1057 \uc0\u1086 \uc0\u1092 \uc0\u1090 , \uc0\u1040 \uc0\u1054 , \uc0\u1047 \uc0\u1040 \uc0\u1054  "\uc0\u1058 \uc0\u1086 \uc0\u1082 \uc0\u1089 \uc0\u1057 \uc0\u1086 \uc0\u1092 \uc0\u1090 -\uc0\u1057 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1100 "}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1050 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1103 \uc0\u1088 \uc0\u1089 \uc0\u1082 }\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1043 \uc0\u1083 \uc0\u1072 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1040 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1072 \uc0\u1083 \uc0\u1102 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1103 . \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1055 \uc0\u1054  \uc0\u1076 \uc0\u1083 \uc0\u1103  PLC (\uc0\u1055 \uc0\u1051 \uc0\u1050 ) \uc0\u1085 \uc0\u1072  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1077  MicroPC \uc0\u1089  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  C/C++. \uc0\u1043 \uc0\u1083 \uc0\u1072 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086  \uc0\u1085 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1102  \uc0\u1040 \uc0\u1057 \uc0\u1059 \uc0\u1058 \uc0\u1055  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1090 \uc0\u1072  \uc0\u1089 \uc0\u1099 \uc0\u1087 \uc0\u1091 \uc0\u1095 \uc0\u1080 \uc0\u1093  \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1086 \uc0\u1074 :{\line}- \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095  \uc0\u1087 \uc0\u1086  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 ;{\line}- \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  \uc0\u1080  \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1074  \uc0\u1091 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1082 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2003 \emdash  \uc0\u1054 \uc0\u1082 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2004\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  1 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u