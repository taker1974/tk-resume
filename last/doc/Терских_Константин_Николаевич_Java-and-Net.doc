091 \uc0\u1097 \uc0\u1080 \uc0\u1093  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090  \uc0\u1087 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1083 \uc0\u1091 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1102  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1055 \uc0\u1054 , \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1089 \uc0\u1091 \uc0\u1097 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091 \uc0\u1102 \uc0\u1097 \uc0\u1077 \uc0\u1075 \uc0\u1086  \uc0\u1055 \uc0\u1054 :{\line}- Linux, FreeBSD, SunOS; {\line}- C, C++, Perl; MySql, Postgres.}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 1998\line \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1057 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1092 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 , \uc0\u1050 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1103 \uc0\u1088 \uc0\u1089 \uc0\u1082 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1077 \uc0\u1093 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 -\uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2025}\cell\pard\intbl\itap1\sl280{\fs24\b Java-\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 }\par\pard\intbl\itap1\sl260{\fs18 SkyPro, Java-\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2013}\cell\pard\intbl\itap1\sb250\sl280{\fs24\b Wonderware Application Server 2012 R2}\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1050 \uc0\u1083 \uc0\u1080 \uc0\u1085 \uc0\u1082 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1085  (Klinkmann), \uc0\u1057 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1090 -\uc0\u1055 \uc0\u1077 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 , \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1089 \uc0\u1090 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2012}\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1092 \uc0\u1080 \uc0\u1075 \uc0\u1091 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  1\uc0\u1057 :\uc0\u1055 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1077 , \uc0\u1055 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072  8 (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  1\uc0\u1057  8)}\par\pard\intbl\itap1\sl260{\fs18 1\uc0\u1057 :\uc0\u1041 \uc0\u1080 \uc0\u1058 , \uc0\u1050 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1103 \uc0\u1088 \uc0\u1089 \uc0\u1082 , 1\uc0\u1057 :\uc0\u1041 \uc0\u1091 \uc0\u1093 \uc0\u1075 \uc0\u1072 \uc0\u1083 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1103 , \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1092 \uc0\u1080 \uc0\u1075 \uc0\u1091 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 )}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  B1 \uc0\u8212  \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1081 }}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 {\cb5\chcfpat5\chcbpat5 Java}  {\cb5\chcfpat5\chcbpat5 Apache\~Maven}  {\cb5\chcfpat5\chcbpat5 Hibernate}  {\cb5\chcfpat5\chcbpat5 Intellij\~IDEA}  {\cb5\chcfpat5\chcbpat5 Liquibase}  {\cb5\chcfpat5\chcbpat5 Mockito}  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1083 \uc0\u1075 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1084 \uc0\u1099 \~\uc0\u1080 \~\uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099 \~\uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077 \~\uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1054 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 \~\uc0\u1082 \uc0\u1086 \uc0\u1076 \uc0\u1072 }  {\cb5\chcfpat5\chcbpat5 Agile}  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \~\uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081 }  {\cb5\chcfpat5\chcbpat5 Bash}  {\cb5\chcfpat5\chcbpat5 Spring\~Data}  {\cb5\chcfpat5\chcbpat5 Spring\~Boot}  {\cb5\chcfpat5\chcbpat5 Spring\~MVC}  {\cb5\chcfpat5\chcbpat5 JUnit}  {\cb5\chcfpat5\chcbpat5 Spring\~Framework}  {\cb5\chcfpat5\chcbpat5 Spring\~Web}  {\cb5\chcfpat5\chcbpat5 Gradle}  {\cb5\chcfpat5\chcbpat5 MS\~Visual\~Studio}  {\cb5\chcfpat5\chcbpat5 Visual\~Studio\~Code}  {\cb5\chcfpat5\chcbpat5 Linux}  {\cb5\chcfpat5\chcbpat5 Docker}  {\cb5\chcfpat5\chcbpat5 Kubernetes}}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa100\sl280{\fs18\uc0\u1048 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090 \uc0\u1089 \uc0\u1103  \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1086 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \par \uc0\u1055 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1072  \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1080  B}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1044 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1056 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1076 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1069 \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1093 \par{\cf1 \uc0\u1055 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1091  (IT Lead)}}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1073 \uc0\u1086  \uc0\u1084 \uc0\u1085 \uc0\u1077 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 \uc0\u1056 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1073 \uc0\u1086 \uc0\u1083 \uc0\u1077 \uc0\u1077  10 \uc0\u1082 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072 .{\line}\uc0\u1056 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1086 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1086  5 \uc0\u1074 \uc0\u1072 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  C#.{\line}{\line}\uc0\u1059 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1096 \uc0\u1085 \uc0\u1086  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1089 \uc0\u1103  \uc0\u1085 \uc0\u1072  \uc0\u1074 \uc0\u1077 \uc0\u1073 -\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1091  \uc0\u1087 \uc0\u1086 \uc0\u1076  Java \uc0\u1080  Spring Boot.{\line}{\line}\uc0\u1057 \uc0\u1074 \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086  \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1074 \uc0\u1085 \uc0\u1086  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1091 \uc0\u1102  Linux, VS Code.{\line}\uc0\u1059 \uc0\u1084 \uc0\u1077 \uc0\u1102  \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1077  \uc0\u1083 \uc0\u1102 \uc0\u1073 \uc0\u1083 \uc0\u1102  \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1090 \uc0\u1100  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102 .{\line}{\line}\uc0\u1041 \uc0\u1077 \uc0\u1079  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1074 \uc0\u1099 \uc0\u1095 \uc0\u1077 \uc0\u1082 .}\cell\row\pard}